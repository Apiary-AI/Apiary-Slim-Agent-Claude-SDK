# Apiary
APIARY_BASE_URL=https://your-apiary-instance.com
APIARY_HIVE_ID=your-hive-id
APIARY_AGENT_ID=your-agent-id
APIARY_API_TOKEN=your-api-token
APIARY_REFRESH_TOKEN=your-refresh-token
APIARY_CAPABILITIES=code,review
APIARY_POLL_INTERVAL=5

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ALLOWED_USERS=123456789,987654321
TELEGRAM_CHAT_ID=your-default-chat-id

# Claude
# Auth: either set ANTHROPIC_API_KEY, or use OAuth by running:
#   docker run -it -v claude_auth:/root/.claude slim-apiary-agent claude
# and opening the printed URL in your browser.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_BUDGET_USD=5.0
CLAUDE_MAX_TURNS=30
CLAUDE_WORKING_DIR=/workspace

# Git / GitHub (for coding tasks: clone, push, PRs)
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=you@example.com
GITHUB_TOKEN=ghp_your-personal-access-token
